gtk-titlebar = false
window-decoration = none
window-show-tab-bar = never
mouse-hide-while-typing = true
focus-follows-mouse = true
shell-integration-features = no-cursor, sudo, ssh-env, ssh-terminfo
cursor-style = block
cursor-style-blink = false
cursor-color = white
cursor-text = black
cursor-opacity = 0.5
right-click-action = ignore
link-previews = false
scrollbar = never
scrollback-limit = 20000000

background-opacity = 0.3
background-opacity-cells = true
# background-blur = true

theme = Espresso
font-family = Maple Mono NF CN
font-style = Bold
font-style-bold = ExtraBold
font-style-italic = Bold Italic
font-style-bold-italic = ExtraBold Italic
font-size = 9
font-feature = -calt, -liga, -dlig

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

keybind = ctrl+q>/=toggle_command_palette
# keybind = ctrl+q>ctrl+q=text:\x11
keybind = ctrl+q>ctrl+q=end_key_sequence
keybind = ctrl+q>j=jump_to_prompt:1
keybind = ctrl+q>k=jump_to_prompt:-1
keybind = ctrl+q>v=new_split:right
keybind = ctrl+q>s=new_split:down
keybind = ctrl+q>f=toggle_split_zoom
keybind = ctrl+q>==equalize_splits
keybind = ctrl+q>x=close_surface

keybind = ctrl+shift+r=activate_key_table:resize
keybind = resize/arrow_up=resize_split:up,10
keybind = resize/arrow_down=resize_split:down,10
keybind = resize/arrow_left=resize_split:left,10
keybind = resize/arrow_right=resize_split:right,10
keybind = resize/catch_all=deactivate_key_table

custom-shader = ~/.config/ghostty/shaders/bloom.glsl
